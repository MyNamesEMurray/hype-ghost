{
  "name": "hype-ghost",
  "version": "1.5.1",
  "description": "AI practice chat for streamers",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "serve": "node src/cli.js",
    "icons": "node scripts/make-icons.mjs",
    "dist": "electron-builder --win"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "electron-updater": "^6.3.9",
    "express": "^4.21.0",
    "obs-websocket-js": "^5.0.6",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^2.1.8",
    "sharp": "^0.33.5"
  },
  "build": {
    "appId": "com.hypeghost.app",
    "productName": "Hype Ghost",
    "publish": {
      "provider": "github",
      "owner": "MyNamesEMurray",
      "repo": "hype-ghost"
    },
    "files": [
      "electron/**",
      "src/**",
      "public/**",
      "assets/**",
      "config.example.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true
    }
  }
}
